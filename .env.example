# Supabase Configuration
# Get these values from your Supabase project dashboard: https://app.supabase.com

# Your Supabase project URL
VITE_SUPABASE_URL=your-project-url.supabase.co

# Your Supabase anon/public key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Instructions:
# 1. Create a new Supabase project at https://app.supabase.com
# 2. Go to Project Settings > API
# 3. Copy the "Project URL" and paste it above
# 4. Copy the "anon public" key and paste it above
# 5. Rename this file to .env (remove .example)
# 6. Never commit your .env file to version control!
