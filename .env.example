# ──────────────────────────────────────────────────────────────
# Zeuservices — environment variables
# Copy to .env.local for local dev, and add these to Vercel →
# Project → Settings → Environment Variables for production.
# ──────────────────────────────────────────────────────────────

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — KEEP SECRET, server only (Dashboard → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile — bot protection on login / signup / password reset.
# Only the SITE key goes here (it's public). Add it in Vercel, then REDEPLOY
# (NEXT_PUBLIC_* is inlined at build time). The SECRET key does NOT go in env —
# paste it into Supabase Dashboard → Authentication → Attack Protection →
# enable CAPTCHA → Turnstile. Leave blank to disable captcha (auth still works).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Google Analytics 4 Measurement ID (Admin → GA → Data Streams → "G-XXXXXXX").
# Leave blank to disable analytics + hide the cookie banner. When set, GA only
# loads after the visitor accepts cookies. Add in Vercel + redeploy.
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token. In Search Console → add a "URL prefix"
# property → choose the "HTML tag" method → copy ONLY the content="..." value here.
# Renders <meta name="google-site-verification">. Add in Vercel + redeploy, then
# click Verify. Leave blank if not using Search Console.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_...
# Stripe webhook signing secret (Developers → Webhooks → your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# Canonical site URL (no trailing slash). Used for Stripe redirects + auth emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend transactional email (Dashboard → API Keys). Sends order confirmation
# and delivery emails. Leave RESEND_API_KEY blank to disable email entirely.
RESEND_API_KEY=re_...
# Verified sender — must be a domain you've verified in Resend.
EMAIL_FROM="Zeuservices <orders@yourdomain.com>"

# Optional: Discord webhook URL for order/support notifications to your staff server
DISCORD_WEBHOOK_URL=

# Optional: auto-assign a Discord role to customers who paid AND connected
# Discord to their account. Requires a Discord bot in your server with the
# "Manage Roles" permission, sitting above the role being granted.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Base role for any customer who has spent $3+ (lifetime, USD).
DISCORD_CUSTOMER_ROLE_ID=
# Optional VIP role for customers who have spent $20+ (lifetime, USD). Assigned
# on top of the base role. Leave blank to disable the VIP tier.
DISCORD_VIP_ROLE_ID=
