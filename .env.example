# =====================================================
# ZEUSERVICES PRODUCTION ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env and fill in your actual keys
# Never commit .env to version control!
# =====================================================

# -----------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------
# FRONTEND URL
# -----------------------------------------------------
# Production domain
VITE_FRONTEND_URL=https://zeuservices.com

# -----------------------------------------------------
# STRIPE CONFIGURATION (PUBLIC KEYS)
# -----------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys

# Test Mode Keys (for development/testing)
VITE_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_your_test_key_here

# Live Mode Keys (for production)
VITE_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_your_live_key_here

# Active key (switch between test/live)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here

# -----------------------------------------------------
# HCAPTCHA CONFIGURATION
# -----------------------------------------------------
# Get from: https://dashboard.hcaptcha.com/sites
VITE_HCAPTCHA_SITEKEY=your_hcaptcha_sitekey_here

# RESEND EMAIL TEMPLATE ID
# Get from: https://resend.com/templates (create your confirmation email template)
VITE_RESEND_CONFIRMATION_TEMPLATE_ID=your_confirmation_template_id_here

# =====================================================
# SUPABASE EDGE FUNCTION ENVIRONMENT VARIABLES
# =====================================================
# Set these in Supabase Dashboard > Edge Functions > Secrets
# https://supabase.com/dashboard/project/YOUR_PROJECT/functions
# =====================================================

# STRIPE_SECRET_KEY_TEST=sk_test_your_test_secret_key_here
# STRIPE_SECRET_KEY_LIVE=sk_live_your_live_secret_key_here
# STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here (active key)
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# HCAPTCHA_SECRET=your_hcaptcha_secret_key_here
# RESEND_API_KEY=your_resend_api_key_here
# FRONTEND_URL=https://zeuservices.com
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key_here

